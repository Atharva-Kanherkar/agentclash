# Auth mode: "dev" (local development) or "workos" (production)
NEXT_PUBLIC_AUTH_MODE=dev

# Backend API URL
# NEXT_PUBLIC_API_URL is used by client code; API_URL (if set) is used
# server-side and can point to an internal network address.
NEXT_PUBLIC_API_URL=http://localhost:8080
# API_URL=http://localhost:8080

# Session encryption secret (32+ characters)
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-real-secret-at-least-32-chars

# WorkOS (required when NEXT_PUBLIC_AUTH_MODE=workos)
# WORKOS_CLIENT_ID=client_01...
# WORKOS_API_KEY=sk_...
# WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
